<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <!-- Nombre de la unidad de persistencia -->
    <persistence-unit name="programacion3UTN" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Declaración de entidades JPA -->
        <class>com.tup.programacion3.entities.Usuario</class>
        <class>com.tup.programacion3.entities.Categoria</class>
        <class>com.tup.programacion3.entities.Producto</class>
        <class>com.tup.programacion3.entities.Pedido</class>
        <class>com.tup.programacion3.entities.DetallePedido</class>

        <properties>
            <!-- Configuración de conexión JDBC -->
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <!-- AUTO_SERVER=TRUE permite conexiones externas (ej: consola H2) mientras la app corre -->
            <!-- DB_CLOSE_DELAY=-1 mantiene la BD abierta mientras la JVM esté activa -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:file:./data/jpa_db;DB_CLOSE_DELAY=-1;AUTO_SERVER=TRUE"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <!-- Dialecto de Hibernate -->
            <!--Hibernate recomienda no aclararlo-->
            <!--property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/-->

            <!-- Estrategia de generación del schema -->
            <!-- 'drop-and-create': borra y recrea las tablas en cada ejecución (ideal para desarrollo) -->
            <!-- Otras opciones: 'create', 'update', 'validate', 'none' -->
            <property name="jakarta.persistence.schema-generation.database.action" value="update"/>

            <!-- Mostrar las sentencias SQL en consola -->
            <property name="hibernate.show_sql" value="true"/>
            <!-- Formatear el SQL en consola para mejor lectura -->
            <property name="hibernate.format_sql" value="true"/>
        </properties>

    </persistence-unit>

</persistence>